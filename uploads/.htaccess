# Deny script execution in uploads directory
php_flag engine off

<FilesMatch "\.(php|phtml|php3|php4|php5|php7|phps|phar|shtml|cgi|pl|py|sh)$">
    Require all denied
</FilesMatch>

Options -ExecCGI -Indexes
AddHandler cgi-script .php .phtml .php3 .php4 .php5 .php7

# Only allow safe file types
<FilesMatch "\.(?!(jpg|jpeg|png|webp|pdf)$)">
    <IfModule mod_authz_core.c>
        # Apache 2.4+
    </IfModule>
</FilesMatch>
